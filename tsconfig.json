{
  "include": ["src/*.ts"],
  "exclude": ["test", "**/*.test.ts", "**/*.spec.ts"],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "node",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["node", "jest"]
  }
}
